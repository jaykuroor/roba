# Normalize all text files to LF in the repository, regardless of each
# contributor's OS or local core.autocrlf setting.
* text=auto eol=lf

*.py text eol=lf
*.md text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.sh text eol=lf
Dockerfile* text eol=lf
Makefile text eol=lf

# Batch/PowerShell scripts (if any are added) keep Windows endings.
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binary files — never touch line endings.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.db binary
